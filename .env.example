# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# URL базы данных PostgreSQL (асинхронный)
# Формат: postgresql+asyncpg://user:password@host:port/database
DB_URL=postgresql+asyncpg://user:password@localhost:5432/animecards

# URL Redis для хранения состояний FSM
# Формат: redis://user:password@host:port/db_number
REDIS_URL=redis://localhost:6379/1

# ID чата для статистики
CHAT_ID=-1001234567890

# ID сообщения со статистикой в чате
MESSAGE_ID=12345